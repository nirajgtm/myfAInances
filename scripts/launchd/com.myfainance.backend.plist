<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  FastAPI backend for the finance dashboard. Serves both the JSON API and
  the built frontend (web/frontend/dist) at http://localhost:@@PORT@@/.

  Templated by scripts/setup.sh — placeholders are replaced before the
  plist is written into ~/Library/LaunchAgents/.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.myfainance.backend</string>

  <key>ProgramArguments</key>
  <array>
    <string>@@REPO_ROOT@@/web/backend/.venv/bin/uvicorn</string>
    <string>main:app</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--port</string>
    <string>@@PORT@@</string>
  </array>

  <key>WorkingDirectory</key>
  <string>@@REPO_ROOT@@/web/backend</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>@@RUNTIME_PATH@@</string>
    <key>FINANCE_CONFIG</key>
    <string>@@DATA_ROOT@@/config.yaml</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <key>StandardOutPath</key>
  <string>@@LOG_DIR@@/backend.log</string>
  <key>StandardErrorPath</key>
  <string>@@LOG_DIR@@/backend.log</string>

  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
